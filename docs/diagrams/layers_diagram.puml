@startuml
!theme plain

' Vertical stack of layers
rectangle "Orchestration Layer" {
    rectangle "Workflow Architect" as Designer
    rectangle "Context Bridge" as Context
    rectangle "Result Synthesizer" as Aggregator
    rectangle "SmolAgent Factory" as SmolAgentFactory
    rectangle "Tool Factory" as ToolFactory
}

rectangle "Composition Layer" {
    rectangle "Graph Runtime" as Orchestrator
    rectangle "Workflow Compiler" as GraphBuilder
    
    rectangle "Example: Web Browsing Workflow" {
        rectangle "Query Planner" as QueryPlanner
        rectangle "Page Navigator" as PageNav
        rectangle "Content Extractor" as ContentExtractor
        rectangle "Form Handler" as FormHandler
        rectangle "Result Validator" as ResultValidator
        
        QueryPlanner --> PageNav : "Search Query"
        PageNav --> ContentExtractor : "Page URL"
        PageNav --> FormHandler : "Form Detected"
        ContentExtractor --> ResultValidator : "Extracted Content"
        FormHandler --> ResultValidator : "Form Results"
        ResultValidator --> QueryPlanner : "Validation Feedback"
    }
}

rectangle "Execution Layer" {
    rectangle "HuggingFace SmolAgent" as SmolAgent
}

rectangle "Primitive Layer" {
    rectangle "Tool Library" as ToolLib {
        rectangle "WebDriver Tools" as WebTools
        rectangle "File System Tools" as FileTools
        rectangle "API Tools" as APITools
        rectangle "Custom Logic Tools" as CustomTools
    }
    rectangle "Tool Executor" as ToolExec
}

Aggregator --> Designer : "Previous Result +\nNext Task"
SmolAgentFactory --> Designer
ToolFactory --> Designer
Designer --> GraphBuilder : "Workflow Specification"
Context --> Orchestrator : "Transfer Knowledge"

GraphBuilder --> Templates : "Build Graph"
GraphBuilder --> Orchestrator
Orchestrator --> QueryAgent
Orchestrator --> NavigationAgent
Orchestrator --> FormHandlingAgent
Orchestrator --> NoteAgent

QueryAgent --> SmolAgent
NavigationAgent --> SmolAgent
FormHandlingAgent --> SmolAgent
NoteAgent --> SmolAgent

SmolAgent --> ToolExec : "Execute Action"
ToolExec --> ToolLib

Results --> Aggregator : "Results"
note right of Results
mutate agent for next task
or redesign if task failed
end note

note right of Designer
Polymorphic Meta-Agent:
1. Adapts internal agent graph based on task
2. Dynamically composes specialist agents
3. Optimizes workflow patterns in real-time
4. Manages inter-agent state transfer
end note

note right of SmolAgent
Agent-within-Agent Pattern:
- RL inspired Observations / Actions Loop
- Observations = tools feedback
- Actions = tools execution
- Already implemented by HuggingFace SmolAgent
end note

note right of WebTools
Pythonic Tools thanks to SmolAgent :
while page.is_loading():
    time.sleep(0.1)
    check_captcha()
    page_text = get_text()
end note
@enduml
graph TD
      A[User Goal] --> B[DarwinMachine - dgm.py]
      B --> C[WorkflowOrchestrator - orchestrator.py]
      C --> D[WorkflowFactory - workflow_factory.py]
      D --> E[LLM Generation<br/>OpenAI Models]
      E --> F[WorkflowRunner - workflow_runner.py]
      F --> G[SmolAgentFactory - smolagent_factory.py]
      G --> H[SmolAgent Instances]
      H --> I[ToolManager - tools_manager.py]
      I --> J[MCP Servers<br/>localhost:5000-5250]

      %% 4-Layer Architecture
      subgraph "Meta-Orchestration Layer"
          B
          C
      end

      subgraph "Workflow Composition Layer"
          D
          E
          F
      end

      subgraph "Agent Execution Layer"
          G
          H
      end

      subgraph "Tool Primitives Layer"
          I
          J
      end

      %% Storage Components
      K[sources/workflows/<br/>UUID-based folders]
      L[sources/memory/<br/>UUID-based folders]
      M[sources/prompts/<br/>System prompts]

      F --> K
      H --> L
      D --> M

      %% External Dependencies
      N[toolomics MCP Server]
      O[Environment Variables<br/>HF_TOKEN, OPENAI_API_KEY]
      P[Health Check Endpoint<br/>http://localhost:5000/health]

      J --> N
      B --> O
      J --> P


      classDef layer1 fill:#e1f5fe
      classDef layer2 fill:#f3e5f5
      classDef layer3 fill:#e8f5e8
      classDef layer4 fill:#fff3e0
      classDef storage fill:#f5f5f5
      classDef external fill:#ffebee

      class B,C layer1
      class D,E,F layer2
      class G,H layer3
      class I,J layer4
      class K,L,M storage
      class N,O,P external